{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "engines": {
  "node": "20.x"
},
  "scripts": {
    "dev:client": "vite dev --port 5000",
    "dev": "NODE_ENV=development tsx --import ./server/instrument.ts server/index.ts",
    "dev:e2e-prod": "tsx --import ./server/instrument.ts server/index.ts",
    "build": "tsx script/build.ts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "check:test": "tsc --project tsconfig.test.json --noEmit",
    "check:i18n": "tsx scripts/check-i18n.ts",
    "check:untranslated-strict": "tsx scripts/check-i18n.ts --strict",
    "check:untranslated-emails": "tsx scripts/check-i18n.ts --strict --namespace emails",
    "i18n:fix": "tsx scripts/check-i18n.ts --fix",
    "i18n:status": "tsx scripts/check-i18n.ts --status",
    "i18n:scaffold": "tsx scripts/scaffold-namespace.ts",
    "i18n:translate": "tsx scripts/translate-i18n.ts",
    "check:seo-structure": "tsx scripts/check-seo-structure.ts",
    "check:replit-namespaces": "tsx scripts/check-replit-namespaces.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:security": "bash scripts/check-zod-error-leak.sh",
    "lint:hardcoded-prefixes": "bash scripts/check-hardcoded-prefixes.sh",
    "db:push": "drizzle-kit push",
    "test": "vitest run",
    "pretest:e2e": "bash scripts/check-chromium.sh",
    "test:e2e": "playwright test",
    "pretest:e2e:smoke": "bash scripts/check-chromium.sh",
    "test:e2e:smoke": "PLAYWRIGHT_NO_SERVER=1 playwright test e2e/landing-page.spec.ts e2e/public-routes-smoke.spec.ts e2e/portal-dashboard.spec.ts e2e/admin-analytics-kpi-cards.spec.ts",
    "check:skip-guards": "bash scripts/check-e2e-skip-guards.sh",
    "check:skip-guard-coverage": "bash scripts/check-skip-guard-coverage.sh",
    "check:skip-pattern": "tsx scripts/check-skip-pattern.ts",
    "check:narration": "tsx scripts/check-narration-fresh.ts",
    "check:narration-path-filters": "tsx scripts/check-narration-path-filters.ts",
    "check:recordings-path-filters": "node scripts/check-recordings-path-filters.mjs",
    "check:sentinel-comments": "node scripts/check-sentinel-comments.mjs",
    "check:emailnotify-mocks": "vitest run scripts/check-emailnotify-mocks.test.ts",
    "check:recordings": "tsx scripts/check-narration-fresh.ts && node video/scripts/check-recordings-fresh.mjs",
    "fingerprint:update-expected": "node video/scripts/update-expected-paths.mjs",
    "narration:generate": "tsx scripts/generate-narration.ts",
    "narration:stamp": "tsx scripts/update-narration-manifest.ts",
    "narration:check": "tsx scripts/update-narration-manifest.ts --check",
    "db:check-drift": "tsx scripts/check-schema-drift.ts",
    "db:check-drift:production": "bash scripts/check-schema-drift-production.sh",
    "db:check-migrate-coverage": "tsx scripts/check-migrate-coverage.ts",
    "prepare": "bash scripts/install-hooks.sh"
  },
  "dependencies": {
    "@fontsource/merriweather": "^5.2.11",
