    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-i18next": "^17.0.7",
    "react-resizable-panels": "^2.1.9",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "supertest": "^7.2.2",
    "tailwind-merge": "^3.3.1",
