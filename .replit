modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0", "github:1.0.0"]

[userenv]

[userenv.shared]
NODE_ENV = "development"
APP_BASE_URL = "https://ibccf.site"
APP_URL = "https://d1886c07-eb59-44ee-a440-c66e8ae6a5d9-00-26oyfm716phkv.sisko.replit.dev"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "spam-protection"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Withdrawal Tutorial Video"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "unit-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lint"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "client-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "script-tests"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "spam-protection"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "grep -q \"returns 429 on the 6th rapid POST from the same IP\" server/__tests__/publicPostRateLimit.test.ts && npx vitest run server/__tests__/publicPostRateLimit.test.ts"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run check"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "Withdrawal Tutorial Video"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5173 npx vite --config video/vite.config.ts"
waitForPort = 5173

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "server-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm test"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "unit-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm test"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "lint"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run lint"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "client-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vitest run client/"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "script-tests"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vitest run --config vitest.scripts.config.ts"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "start"]
build = ["npm", "run", "build"]

