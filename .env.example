# Database Connection (Required)
# Any standard PostgreSQL connection string works — Neon, Supabase, Hostinger's
# own Postgres, or a self-managed instance on the same VPS.
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# Session Secret (Required)
# Generate a random string of at least 32 characters for session encryption
# (e.g. `openssl rand -hex 32`).
SESSION_SECRET=your-super-secret-session-key-change-this

# Admin credentials (Required)
ADMIN_USERNAME=change-me-to-a-unique-username
ADMIN_PASSWORD=change-me-to-a-strong-unique-password

# OpenAI API Key (Optional - for AI features)
OPENAI_API_KEY=sk-your-openai-api-key

# Public Base URL (Recommended for self-hosting)
# The public origin this app is served from (no trailing slash), e.g.
# https://forum.example.com. Used to build absolute links in transactional
# emails, AI-alert admin links, and CORS allow-listing. On Replit this is
# auto-derived from REPLIT_DOMAINS/REPLIT_DEV_DOMAIN when unset; everywhere
# else (Hostinger, a bare VPS, etc.) you should set it explicitly or the app
# falls back to a hard-coded canonical domain.
PUBLIC_BASE_URL=https://your-domain.example.com

# Environment
NODE_ENV=production

# Port (Hostinger will set this automatically; PM2/Nginx setups should match
# the port configured in the Nginx reverse-proxy config)
PORT=8080

# SMTP (Optional - required for transactional email; degrades gracefully if unset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM_NAME=IBCCF
# SMTP_FROM_ADDRESS=no-reply@example.com
# SMTP_REPLY_TO=support@example.com

# Sentry (Optional - error monitoring)
# SENTRY_DSN=
# VITE_SENTRY_DSN=

# Bulk action confirmation threshold (Optional - defaults to 20)
# Admin bulk Email / Block IPs / Access Code sends above this many cases
# show a confirmation dialog instead of firing immediately. Must be a
# positive integer; any other value falls back to the default of 20.
# VITE_BULK_CONFIRM_THRESHOLD=20
